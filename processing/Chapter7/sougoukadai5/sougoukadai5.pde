size(400,100);
int x = -25;

for(int i=50; i<=300; i +=50){   // x方向に50ずつずらしながらループ

  if(i <= 150){
    fill(255,0,0);         // 左側3つは赤
  }else{
    fill(150,200,0);       // 右側は黄緑系
  }
  ellipse(x + i,25,50,50); // 外側の円を描画
  
  if(i % 100 == 0){
    fill(0,0,0);          // 100の倍数位置は黒
  }else{
    fill(255,255,255);    // それ以外は白 }

  ellipse(x + i,25,20,20); // 内側の小さい円を描画
}
